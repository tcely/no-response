{
  "name": "no-response-tcely",
  "version": "0.1.0",
  "private": true,
  "description": "A GitHub Action that closes Issues where the author hasn't responded to a request for more information",
  "main": "src/main.ts",
  "type": "module",
  "scripts": {
    "ci": "bun run format && bun run lint && bun run test",
    "build": "bun build --compile --outfile bin/no-response-bin ./src/main.ts",
    "format:write": "bun x -- prettier --write **/*.ts **/*.md **/*.yaml **/*.yml",
    "format": "bun x -- prettier --check **/*.ts **/*.md **/*.yaml **/*.yml",
    "lint": "bun x -- eslint src/**/*.ts",
    "test": "bun test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tcely/no-response.git"
  },
  "keywords": [
    "actions",
    "bun",
    "typescript"
  ],
  "author": "lee-dohm",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0",
    "scramjet": "^4.36.0"
  },
  "devDependencies": {
    "@octokit/webhooks-types": "^7.6.1",
    "@types/node": "^24.0.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9.21.0",
    "eslint-plugin-github": "^5.1.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  }
}
